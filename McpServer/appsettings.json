{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "AutomationMcp": {
    "ListenUrl": "http://127.0.0.1:8081",
    "BridgePipeName": "AutomationBridgePipe",
    "BridgeTimeoutMs": 30000,
    "EnableTrayIcon": true,
    "LogRoot": "Logs/McpServer"
  }
}
