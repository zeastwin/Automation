{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1;[::1]",
  "AutomationMcp": {
    "ListenHost": "127.0.0.1",
    "ListenPort": 8081,
    "BridgePipeName": "AutomationBridgePipe",
    "BridgeTimeoutMs": 30000,
    "EnableTrayIcon": true,
    "LogRoot": "D:\\AutomationLogs\\McpServer"
  }
}
