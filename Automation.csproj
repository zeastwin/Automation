  <Target Name="RemoveLegacySimulationArtifacts" AfterTargets="Build">
    <RemoveDir Directories="$(TargetDir)SimulationRuns;$(TargetDir)SimulationScenarios" />
  </Target>
  <!-- Goose 受管 Markdown 同时保留程序集资源和程序目录副本；这里只清理根目录冗余文件。 -->
  <Target Name="RemoveRedundantOutputArtifacts" AfterTargets="Build">
    <ItemGroup>
      <RedundantOutputFile Include="$(TargetDir)*.xml" Exclude="$(TargetDir)Automation.DeviceSdk.xml" />
      <RedundantOutputFile Include="$(TargetDir)README.md" />
      <RedundantOutputFile Include="$(TargetDir)intent_templates.json" />
    </ItemGroup>
    <Delete Files="@(RedundantOutputFile)" />
  </Target>
  <Target Name="WritePlatformRuntimeManifest" AfterTargets="Build">
    <WriteLinesToFile File="$(TargetDir)PlatformRuntimeManifest.json" Lines="{ &quot;apiVersion&quot;: &quot;$(PlatformApiVersion)&quot;, &quot;platformVersion&quot;: &quot;$(PlatformRuntimeVersion)&quot;, &quot;architecture&quot;: &quot;x64&quot;, &quot;configuration&quot;: &quot;$(Configuration)&quot; }" Overwrite="true" Encoding="UTF-8" />
  </Target>
  <!-- Release 运行包不携带调试符号；递归清理可同时移除项目引用遗留的 PDB。 -->
  <Target Name="SlimReleaseOutput" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <ItemGroup>
      <ReleaseSymbolFile Include="$(TargetDir)**\*.pdb" />
    </ItemGroup>
    <Delete Files="@(ReleaseSymbolFile)" />
  </Target>
