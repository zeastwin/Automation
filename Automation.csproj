  <Target Name="CopySourceDllFiles" AfterTargets="Build">
    <ItemGroup>
      <SourceDllFiles Include="SourceDLL\**\*.dll" />
    </ItemGroup>
    <Copy Condition="'@(SourceDllFiles)' != ''" SourceFiles="@(SourceDllFiles)" DestinationFiles="@(SourceDllFiles->'$(TargetDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
  </Target>
  <!-- 源码只作为 Compile 项显示；构建时从 obj 中间副本生成源码快照资源，避免解决方案出现同名双节点。 -->
  <Target Name="PrepareEmbeddedCustomFunctionsSource" BeforeTargets="PrepareResourceNames">
    <PropertyGroup>
      <CustomFunctionsSourceSnapshotDirectory>$(IntermediateOutputPath)EmbeddedSources</CustomFunctionsSourceSnapshotDirectory>
      <CustomFunctionsSourceSnapshot>$(CustomFunctionsSourceSnapshotDirectory)\Hmi.CustomFunctions.cs.txt</CustomFunctionsSourceSnapshot>
    </PropertyGroup>
    <MakeDir Directories="$(CustomFunctionsSourceSnapshotDirectory)" />
    <Copy SourceFiles="Hmi\CustomFunctions.cs" DestinationFiles="$(CustomFunctionsSourceSnapshot)" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="ProvisionProcessAuthoringSkillInOutput" AfterTargets="Build">
    <PropertyGroup>
      <ProcessAuthoringSkillOutputDirectory>$(TargetDir).agents\skills\automation-process-authoring</ProcessAuthoringSkillOutputDirectory>
    </PropertyGroup>
    <MakeDir Directories="$(ProcessAuthoringSkillOutputDirectory)" />
    <Copy SourceFiles="Assets\Goose\Skills\automation-process-authoring\SKILL.md" DestinationFolder="$(ProcessAuthoringSkillOutputDirectory)" SkipUnchangedFiles="true" />
    <Copy SourceFiles="Assets\Goose\Skills\automation-process-authoring\.automation-skill-version" DestinationFolder="$(ProcessAuthoringSkillOutputDirectory)" SkipUnchangedFiles="true" />
  </Target>
  <Target Name="RemoveUnsupportedNativeGitLibraries" AfterTargets="Build">
    <ItemGroup>
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\linux-arm" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\linux-arm64" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\linux-musl-arm" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\linux-musl-arm64" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\linux-musl-x64" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\linux-ppc64le" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\linux-x64" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\osx-arm64" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\osx-x64" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\win32\arm64" />
      <UnsupportedNativeGitDirectory Include="$(TargetDir)lib\win32\x86" />
    </ItemGroup>
    <RemoveDir Directories="@(UnsupportedNativeGitDirectory)" />
  </Target>
  <!-- Goose 受管 Markdown 同时保留程序集资源和程序目录副本；这里只清理根目录冗余文件。 -->
