  <!--
    直接调用 Compile 目标时，旧式 .NET Framework 项目默认不会执行 PrepareResources，
    会生成不含任何内嵌资源但仍可通过编译的残缺 EXE。将资源准备纳入 Compile 契约，
    保证命令行增量验证与完整 Build 产物使用同一条资源链路。
  -->
  <PropertyGroup>
    <CompileDependsOn>PrepareResources;$(CompileDependsOn)</CompileDependsOn>
  </PropertyGroup>
  <Target Name="ValidateEmbeddedResourceCompileInputs" BeforeTargets="CoreCompile" DependsOnTargets="PrepareResources;_GenerateCompileInputs">
